# Copy to .env and fill in. .env is gitignored.

# Hugging Face — needed only for gated/private models; SetFit/mnli and RoBERTa are public.
HF_TOKEN=

# Optional experiment tracking
WANDB_API_KEY=
WANDB_PROJECT=distill-nli

# Optional: pin HF caches to a local folder so they don't bloat ~/.cache
# HF_HOME=./hf_cache
